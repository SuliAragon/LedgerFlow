<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.facturapp.presentation.controller.LoginController"
            styleClass="login-root"
            prefWidth="1100" prefHeight="700">

    <!-- Panel izquierdo: branding -->
    <left>
        <VBox styleClass="login-brand-panel" alignment="CENTER" spacing="20" prefWidth="420">
            <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>

            <Label text="FacturApp" styleClass="brand-title"/>
            <Label text="Sistema de Facturación Profesional"
                   styleClass="brand-subtitle" wrapText="true" textAlignment="CENTER"/>

            <VBox spacing="14" alignment="CENTER_LEFT" styleClass="feature-list">
                <padding><Insets top="40"/></padding>
                <Label text="✓  Gestión de clientes y productos" styleClass="feature-item"/>
                <Label text="✓  Facturas con PDF automático"     styleClass="feature-item"/>
                <Label text="✓  Estadísticas e historial"        styleClass="feature-item"/>
                <Label text="✓  Base de datos local segura"      styleClass="feature-item"/>
            </VBox>

            <Label text="v1.0.0 · Java 21 + JavaFX" styleClass="brand-version"/>
        </VBox>
    </left>

    <!-- Panel derecho: StackPane con LOGIN y REGISTRO -->
    <center>
        <StackPane styleClass="login-form-panel">

            <!-- ===== PANEL LOGIN ===== -->
            <VBox fx:id="panelLogin" alignment="CENTER" spacing="0">
                <padding><Insets top="70" right="80" bottom="70" left="80"/></padding>

                <VBox spacing="8" alignment="CENTER">
                    <padding><Insets bottom="36"/></padding>
                    <Label text="Iniciar Sesión" styleClass="login-title"/>
                    <Label text="Introduce tus credenciales para continuar" styleClass="login-subtitle"/>
                </VBox>

                <Label text="Usuario" styleClass="form-label"/>
                <TextField fx:id="txtUsername" promptText="Nombre de usuario"
                           styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="14"/></VBox.margin>
                </TextField>

                <Label text="Contraseña" styleClass="form-label"/>
                <PasswordField fx:id="txtPassword" promptText="Contraseña"
                              styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="8"/></VBox.margin>
                </PasswordField>

                <Label fx:id="lblError" text="" styleClass="form-error" wrapText="true" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="14"/></VBox.margin>
                </Label>

                <Button fx:id="btnLogin" text="Entrar" onAction="#onLogin"
                        styleClass="btn-primary" maxWidth="Infinity" defaultButton="true">
                    <VBox.margin><Insets bottom="20"/></VBox.margin>
                </Button>

                <!-- Enlace a registro -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="¿Nuevo en FacturApp?" styleClass="login-hint"/>
                    <Button text="Crear cuenta" onAction="#mostrarRegistro"
                            styleClass="link-btn"/>
                </HBox>

                <VBox alignment="CENTER">
                    <padding><Insets top="20"/></padding>
                    <Label text="Demo: admin / admin123" styleClass="login-hint"/>
                </VBox>
            </VBox>

            <!-- ===== PANEL REGISTRO ===== -->
            <VBox fx:id="panelRegistro" alignment="CENTER" spacing="0" visible="false" managed="false">
                <padding><Insets top="50" right="80" bottom="50" left="80"/></padding>

                <VBox spacing="8" alignment="CENTER">
                    <padding><Insets bottom="28"/></padding>
                    <Label text="Crear Cuenta" styleClass="login-title"/>
                    <Label text="Regístrate para acceder a FacturApp" styleClass="login-subtitle"/>
                </VBox>

                <Label text="Usuario *" styleClass="form-label"/>
                <TextField fx:id="txtRegUsername" promptText="Nombre de usuario"
                           styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </TextField>

                <Label text="Email" styleClass="form-label"/>
                <TextField fx:id="txtRegEmail" promptText="correo@ejemplo.com"
                           styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </TextField>

                <Label text="Contraseña *" styleClass="form-label"/>
                <PasswordField fx:id="txtRegPassword" promptText="Mínimo 6 caracteres"
                              styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </PasswordField>

                <Label text="Confirmar contraseña *" styleClass="form-label"/>
                <PasswordField fx:id="txtRegPasswordConfirm" promptText="Repite la contraseña"
                              styleClass="form-input" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="8"/></VBox.margin>
                </PasswordField>

                <Label fx:id="lblRegError" text="" styleClass="form-error" wrapText="true" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </Label>

                <Button text="Crear Cuenta" onAction="#onRegistrar"
                        styleClass="btn-success" maxWidth="Infinity">
                    <VBox.margin><Insets bottom="14"/></VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="¿Ya tienes cuenta?" styleClass="login-hint"/>
                    <Button text="Iniciar sesión" onAction="#mostrarLogin" styleClass="link-btn"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
